{
    "compilerOptions": {
        "target": "es5",
        "module": "es6",
        "moduleResolution": "node",
        "esModuleInterop": true,
        "allowSyntheticDefaultImports": true,
        "noImplicitAny": true,
        "noUnusedLocals": true,
        "removeComments": true,
        "sourceMap": true,
        "outDir": "./dist/",
        "allowJs": true,
        "typeRoots": [
            "node_modules/@types"
        ],
        "resolveJsonModule": true,
        "downlevelIteration": true,
        "skipLibCheck": true
    }
}
